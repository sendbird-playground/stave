{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/agent-hooks/session-start-context.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/agent-hooks/user-prompt-submit.mjs"
          }
        ]
      }
    ]
  }
}
