{
  "name": "stave",
  "private": true,
  "version": "0.0.2",
  "description": "Stave: Agentic Coding IDE.",
  "author": "astyfx",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "server-dev": "bun run server/dev-server.ts",
    "dev": "vite",
    "dev:all": "concurrently -n server,client -c blue,green \"bun run server-dev\" \"bun run dev\"",
    "dev:desktop": "electron-vite dev",
    "dev:desktop:poll": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=120 electron-vite dev",
    "build": "tsc --noEmit && vite build",
    "build:desktop": "tsc --noEmit && electron-vite build",
    "package:desktop": "bun run build:desktop && electron-builder --config electron-builder.yml --dir",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "qa:ui": "bun run test:e2e",
    "rebuild:electron-deps": "bun run rebuild:better-sqlite3:electron && bun run rebuild:node-pty:electron",
    "rebuild:better-sqlite3:electron": "cd node_modules/better-sqlite3 && ../../node_modules/.bin/node-gyp rebuild --runtime=electron --target=40.6.1 --arch=x64 --dist-url=https://www.electronjs.org/headers --build-from-source",
    "rebuild:node-pty:electron": "node_modules/.bin/electron-rebuild -f -w node-pty",
    "test:ci": "bun run typecheck && bun test && bun run build && bun run build:desktop"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.68",
    "@fontsource-variable/geist": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@openai/codex-sdk": "^0.107.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-diff-viewer-continued": "^4.1.2",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.14.1",
    "shadcn": "^4.0.0",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
